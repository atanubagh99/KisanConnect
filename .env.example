# ========================
# KisanConnect Environment Variables
# ========================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database (production)
DATABASE_URL=jdbc:postgresql://localhost:5432/kisanconnect
DATABASE_USERNAME=kisanconnect
DATABASE_PASSWORD=your_password_here

# Groq API (FREE — OpenAI-compatible LLM)
# Sign up: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your-groq-api-key-here

# HuggingFace API (FREE — STT, TTS, Translation)
# Sign up: https://huggingface.co/settings/tokens → New token (Read)
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# Telegram Bot
# Get your token: Talk to @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_USERNAME=KisanVoiceBot

# Spring profiles (dev | staging | prod)
SPRING_PROFILES_ACTIVE=dev
